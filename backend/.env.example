PORT=5000
# Preferred: DB user password only in MONGODB_PASSWORD (rotate in Atlas if exposed).
MONGODB_USER=your_atlas_username
MONGODB_PASSWORD=your_atlas_password
MONGODB_HOST=your_cluster.xxxxx.mongodb.net
MONGODB_DB=your_database_name
# If you see querySrv ECONNREFUSED (Windows/Node): optional explicit DNS for SRV lookups
# MONGODB_DNS_SERVERS=8.8.8.8,8.8.4.4
# MONGODB_SKIP_DNS_OVERRIDE=1
# Legacy only — avoid embedding passwords in URIs in shared or scanned files.
# MONGODB_URI=mongodb+srv://user:pass@host/db?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLIENT_URL=http://localhost:5173
WHATSAPP_NUMBER=923001234567